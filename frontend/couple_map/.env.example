# 백엔드 API URL
# 로컬 개발: http://localhost:8080
# 실제 기기: PC의 로컬 IP 사용 (예: http://192.168.0.100:8080)
BASE_URL=http://localhost:8080

# 카카오 로그인
KAKAO_NATIVE_APP_KEY=YOUR_KAKAO_NATIVE_APP_KEY
KAKAO_JAVASCRIPT_APP_KEY=YOUR_KAKAO_JAVASCRIPT_APP_KEY

# 구글 로그인 (Firebase)
# google-services.json 파일에서 자동으로 읽음

# 네이버 로그인
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET
NAVER_CLIENT_NAME=couple_map
