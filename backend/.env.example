# Database
DB_URL=jdbc:mysql://your-mysql-host:3306/couplemap?serverTimezone=Asia/Seoul
DB_USERNAME=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars

# OAuth2 - Naver
NAVER_ID=your_naver_client_id
NAVER_SECRET=your_naver_client_secret

# OAuth2 - Kakao
KAKAO_ID=your_kakao_client_id
KAKAO_SECRET=your_kakao_client_secret

# OAuth2 - Google
GOOGLE_ID=your_google_client_id
GOOGLE_SECRET=your_google_client_secret

# AWS S3
S3_ACCESS_KEY=your_aws_access_key
S3_SECRET_KEY=your_aws_secret_key
S3_BUCKET_NAME=your_bucket_name

# Redis (docker-compose 내부 서비스명 사용)
REDIS_HOST=redis
REDIS_PORT=6379

# CORS
APP_CORS_ALLOWED_ORIGINS=https://your-domain.com

# OAuth Redirect
OAUTH_REDIRECT_BASE_URL=https://your-domain.com

# Docker Hub username (docker-compose image 이름에 사용)
DOCKER_USERNAME=your_dockerhub_username
